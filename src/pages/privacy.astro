---
import Base from '../layouts/Base.astro';
const title = 'Privacy Policy — Bankrolly';
const description = 'How Bankrolly handles your data. Poker sessions, bankroll and notes are stored locally on your device. We do not sell or share your poker data.';
---
<Base title={title} description={description}>
  <section>
    <article class="prose">
      <h1>Privacy Policy</h1>
      <p class="updated">Last updated: May 12, 2026</p>

      <h2>Introduction</h2>
      <p>Bankrolly ("the App") respects your privacy. This Privacy Policy explains what information is collected and how it is used.</p>

      <h2>Information We Collect</h2>
      <h3>Account Information</h3>
      <p>When you create an account, we may collect:</p>
      <ul>
        <li>Email address</li>
        <li>Authentication provider information</li>
      </ul>
      <p>Authentication is handled securely through Clerk.</p>

      <h3>Subscription Information</h3>
      <p>If you purchase Bankrolly Pro, Apple may share subscription status information with us to verify your active subscription.</p>

      <h3>Poker Data</h3>
      <p>All poker sessions, bankroll information, hand notes, analytics, and trip data are stored locally on your device unless explicitly synced by the user in the future.</p>
      <p>We do not sell or share your poker data.</p>

      <h2>How We Use Information</h2>
      <p>We use collected information to:</p>
      <ul>
        <li>Authenticate users</li>
        <li>Manage subscriptions</li>
        <li>Improve app functionality</li>
        <li>Provide customer support</li>
      </ul>

      <h2>Third-Party Services</h2>
      <p>Bankrolly may use:</p>
      <ul>
        <li>Clerk for authentication</li>
        <li>RevenueCat for subscription management</li>
        <li>Apple services for payments and subscriptions</li>
      </ul>

      <h2>Data Sharing</h2>
      <p>We do not sell personal information.</p>

      <h2>Children's Privacy</h2>
      <p>Bankrolly is not intended for children under 13 years old.</p>

      <h2>Contact</h2>
      <p>For privacy-related questions, contact: <a href="mailto:support@bankrolly.online">support@bankrolly.online</a></p>

      <h2>Changes</h2>
      <p>This Privacy Policy may be updated periodically.</p>
    </article>
  </section>
</Base>
