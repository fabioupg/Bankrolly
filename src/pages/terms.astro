---
import Base from '../layouts/Base.astro';
const title = 'Terms of Service — Bankrolly';
const description = 'Bankrolly Terms of Service. Bankrolly is a poker bankroll and session tracking application for informational and analytical purposes only.';
---
<Base title={title} description={description}>
  <section>
    <article class="prose">
      <h1>Terms of Service</h1>
      <p class="updated">Last updated: May 12, 2026</p>

      <h2>Acceptance of Terms</h2>
      <p>By using Bankrolly, you agree to these Terms of Service.</p>

      <h2>Service Description</h2>
      <p>Bankrolly is a poker bankroll and session tracking application designed for informational and analytical purposes only.</p>
      <p>The app does not provide gambling services or facilitate real-money betting.</p>

      <h2>Subscriptions</h2>
      <p>Bankrolly Pro is offered as an auto-renewing subscription.</p>
      <p>Available plans may include:</p>
      <ul>
        <li>Monthly subscription</li>
        <li>Yearly subscription</li>
      </ul>
      <p>Subscriptions automatically renew unless canceled at least 24 hours before the end of the billing period.</p>
      <p>You may cancel your subscription anytime through your Apple ID account settings.</p>

      <h2>Payments and Refunds</h2>
      <p>Payments are handled by Apple through the App Store.</p>
      <p>Refund requests are subject to Apple's refund policies.</p>

      <h2>Acceptable Use</h2>
      <p>You agree not to:</p>
      <ul>
        <li>Abuse the service</li>
        <li>Reverse engineer the application</li>
        <li>Use the app for illegal activities</li>
      </ul>

      <h2>Disclaimer</h2>
      <p>Bankrolly is provided "as is" without warranties of any kind.</p>
      <p>The app is intended for tracking and analysis purposes only.</p>

      <h2>Limitation of Liability</h2>
      <p>To the maximum extent permitted by law, Bankrolly shall not be liable for any indirect, incidental, or consequential damages.</p>

      <h2>Apple Standard EULA</h2>
      <p>The app also uses Apple's Standard End User License Agreement:</p>
      <p><a href="https://www.apple.com/legal/internet-services/itunes/dev/stdeula/" target="_blank" rel="noopener">https://www.apple.com/legal/internet-services/itunes/dev/stdeula/</a></p>

      <h2>Contact</h2>
      <p><a href="mailto:bankrolly@fabulousio.com">bankrolly@fabulousio.com</a></p>

      <h2>Changes</h2>
      <p>These Terms may be updated periodically.</p>
    </article>
  </section>
</Base>
