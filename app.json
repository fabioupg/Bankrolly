{
  "expo": {
    "name": "Bankrolly",
    "slug": "pokerledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bankrolly",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f0d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bankrolly.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f0d"
      },
      "package": "com.bankrolly.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "651f5960-0c6f-4e80-8a87-e6d63f922f3f"
      }
    },
    "owner": "fabio_upg",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/651f5960-0c6f-4e80-8a87-e6d63f922f3f"
    }
  }
}
