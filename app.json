{
  "expo": {
    "name": "Bankrolly",
    "slug": "pokerledger",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "bankrolly",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bankrolly.app",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true,
        "NSCameraUsageDescription": "Bankrolly lets you photograph a spot or board and attach it to your live session notes.",
        "NSPhotoLibraryUsageDescription": "Bankrolly lets you attach photos to your live session notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f0d"
      },
      "package": "com.bankrolly.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-live-activity",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bankrolly lets you attach photos to your live session notes.",
          "cameraPermission": "Bankrolly lets you photograph a spot or board and attach it to your live session notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "651f5960-0c6f-4e80-8a87-e6d63f922f3f"
      }
    },
    "owner": "fabio_upg",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/651f5960-0c6f-4e80-8a87-e6d63f922f3f"
    }
  }
}
